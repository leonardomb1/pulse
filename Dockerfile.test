FROM golang:1.25-alpine AS build
RUN apk add --no-cache gcc musl-dev linux-headers
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /pulse ./cmd/pulse/

FROM alpine:3.21
RUN apk add --no-cache iptables iproute2 curl bind-tools
COPY --from=build /pulse /usr/local/bin/pulse
ENTRYPOINT ["pulse"]
